# Normalize text files in the repository to LF (GitHub standard)
* text=auto eol=lf

# Keep Windows-native scripts as CRLF in working tree
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Keep shell/config/docs files LF
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
